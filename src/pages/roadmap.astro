---
import BaseLayout from '../layouts/BaseLayout.astro';
import RoadmapBoard from '../components/RoadmapBoard.astro';
import VoteButton from '../components/VoteButton.astro';
import meta from '../data/roadmap-meta.json';

const lastUpdated = new Date(meta.lastUpdated).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title="Roadmap — InterLink" description="See what's coming next for CSE ICON InterLink. Vote on features you'd like to see.">
  <section class="py-10 sm:py-14">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center">
        <h1 class="section-heading">Product Roadmap</h1>
        <p class="section-description">
          See what we're working on and what's next. Vote on the features that matter most to you.
        </p>
        <p class="mt-3 text-sm text-[var(--color-text-muted)]">
          Last updated: {lastUpdated}
        </p>
      </div>
    </div>
  </section>

  <section class="pb-14">
    <RoadmapBoard />
  </section>

  <VoteButton />

  <div class="bg-brand-600 py-4 text-center">
    <p class="text-xs text-white/50">&copy; {new Date().getFullYear()} CSE ICON, Inc. All rights reserved.</p>
  </div>
</BaseLayout>
