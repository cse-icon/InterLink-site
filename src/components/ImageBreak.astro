---
interface Props {
  src: string;
  alt: string;
  caption?: string;
  variant?: 'full' | 'contained' | 'split';
  background?: 'light' | 'dark' | 'brand';
}

const { src, alt, caption, variant = 'contained', background = 'light' } = Astro.props;

const bgClasses: Record<string, string> = {
  light: 'bg-slate-50 dark:bg-slate-800/50',
  dark: 'bg-slate-900 dark:bg-slate-900',
  brand: 'bg-brand-600',
};
---

{variant === 'full' && (
  <section class={`${bgClasses[background]} py-6 sm:py-10`}>
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <img src={src} alt={alt} class="w-full rounded-xl shadow-lg" loading="lazy" />
      {caption && (
        <p class={`mt-3 text-center text-sm ${background === 'dark' || background === 'brand' ? 'text-white/60' : 'text-[var(--color-text-muted)]'}`}>
          {caption}
        </p>
      )}
    </div>
  </section>
)}

{variant === 'contained' && (
  <section class={`${bgClasses[background]} py-6 sm:py-10`}>
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <img src={src} alt={alt} class="w-full rounded-xl shadow-lg" loading="lazy" />
      {caption && (
        <p class={`mt-3 text-center text-sm ${background === 'dark' || background === 'brand' ? 'text-white/60' : 'text-[var(--color-text-muted)]'}`}>
          {caption}
        </p>
      )}
    </div>
  </section>
)}

{variant === 'split' && (
  <section class={`${bgClasses[background]} overflow-hidden`}>
    <img src={src} alt={alt} class="h-48 w-full object-cover sm:h-64 lg:h-72" loading="lazy" />
  </section>
)}
