---
interface Props {
  title: string;
  description: string;
  icon?: string;
}

const { title, description } = Astro.props;
---

<div class="card group">
  <h3 class="text-base font-semibold leading-tight">{title}</h3>
  <p class="mt-1 text-sm text-[var(--color-text-muted)]">{description}</p>
</div>
