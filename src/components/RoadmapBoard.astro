---
import RoadmapItem from './RoadmapItem.astro';
import roadmapData from '../data/roadmap.json';

interface RoadmapEntry {
  id: string;
  title: string;
  summary: string;
  category: string;
  status: string;
  releasedIn: string | null;
  votes: number;
}

const items = roadmapData as RoadmapEntry[];

const columns = [
  { key: 'Backlog', label: 'Backlog', color: 'bg-slate-400' },
  { key: 'Investigating', label: 'Investigating', color: 'bg-yellow-400' },
  { key: 'In Development', label: 'In Development', color: 'bg-blue-400' },
  { key: 'Released', label: 'Released', color: 'bg-green-400' },
];

const categories = [...new Set(items.map((i) => i.category))].sort();
---

<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
  <!-- Category filter -->
  <div class="mb-8 flex flex-wrap items-center gap-2">
    <span class="text-sm font-medium text-[var(--color-text-muted)]">Filter:</span>
    <button
      class="category-filter badge badge-platform active-filter rounded-lg px-3 py-1.5 text-sm font-medium transition-colors"
      data-category="all"
    >
      All
    </button>
    {categories.map((cat) => {
      const badgeClass = {
        PI: 'badge-pi',
        'OPC UA': 'badge-opcua',
        Platform: 'badge-platform',
        Configuration: 'badge-configuration',
        Security: 'badge-security',
        Federation: 'badge-federation',
      }[cat] || 'badge-platform';
      return (
        <button
          class={`category-filter badge ${badgeClass} rounded-lg px-3 py-1.5 text-sm font-medium opacity-60 transition-all hover:opacity-100`}
          data-category={cat}
        >
          {cat}
        </button>
      );
    })}
  </div>

  <!-- Kanban board -->
  <div class="grid gap-6 lg:grid-cols-4">
    {columns.map((col) => {
      const colItems = items.filter((i) => i.status === col.key);
      return (
        <div class="flex flex-col">
          <div class="mb-4 flex items-center gap-2">
            <div class={`h-2.5 w-2.5 rounded-full ${col.color}`} />
            <h3 class="text-sm font-semibold">{col.label}</h3>
            <span class="text-xs text-[var(--color-text-muted)]">({colItems.length})</span>
          </div>
          <div class="flex flex-col gap-3 roadmap-column" data-column-status={col.key}>
            {colItems.map((item) => (
              <RoadmapItem
                id={item.id}
                title={item.title}
                summary={item.summary}
                category={item.category}
                status={item.status}
                releasedIn={item.releasedIn}
                votes={item.votes}
              />
            ))}
            {colItems.length === 0 && (
              <p class="rounded-lg border border-dashed border-[var(--color-border)] p-6 text-center text-sm text-[var(--color-text-muted)]">
                No items yet
              </p>
            )}
          </div>
        </div>
      );
    })}
  </div>
</div>

<script>
  // Category filtering
  const filters = document.querySelectorAll<HTMLButtonElement>('.category-filter');
  const cards = document.querySelectorAll<HTMLElement>('[data-category]');

  filters.forEach((btn) => {
    btn.addEventListener('click', () => {
      const cat = btn.dataset.category;

      filters.forEach((f) => {
        f.classList.toggle('opacity-60', f !== btn);
        f.classList.toggle('active-filter', f === btn);
      });

      cards.forEach((card) => {
        if (card.classList.contains('category-filter')) return;
        if (cat === 'all' || card.dataset.category === cat) {
          card.style.display = '';
        } else {
          card.style.display = 'none';
        }
      });
    });
  });
</script>
