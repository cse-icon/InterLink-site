---
import FeatureCard from './FeatureCard.astro';

interface Feature {
  title: string;
  description: string;
}

interface Props {
  title: string;
  description: string;
  features: Feature[];
  icon: string;
  reversed?: boolean;
}

const { title, description, features, icon, reversed = false } = Astro.props;
---

<section class="py-8 sm:py-12" id={title.toLowerCase().replace(/[^a-z0-9]+/g, '-')}>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class={`flex flex-col gap-8 lg:flex-row lg:items-start lg:gap-12 ${reversed ? 'lg:flex-row-reverse' : ''}`}>
      <div class="lg:w-1/3 lg:sticky lg:top-24">
        <div class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-brand-100 text-brand-700 dark:bg-brand-900/30 dark:text-brand-400">
          <Fragment set:html={icon} />
        </div>
        <h2 class="section-heading mt-3">{title}</h2>
        <p class="section-description">{description}</p>
      </div>
      <div class="grid flex-1 gap-3 sm:grid-cols-2">
        {features.map((feature) => (
          <FeatureCard title={feature.title} description={feature.description} />
        ))}
      </div>
    </div>
  </div>
</section>
